---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout>
  <div class="terminal-window">
    <!-- Window Chrome -->
    <div class="window-chrome">
      <div class="window-dots">
        <span class="window-dot window-dot--close"></span>
        <span class="window-dot window-dot--minimize"></span>
        <span class="window-dot window-dot--maximize"></span>
      </div>
      <span class="window-title"><span class="prompt__user">osim</span><span class="prompt__separator">@</span><span class="prompt__host">dev</span><span class="prompt__separator">:</span> <span class="prompt__path">~/blog</span></span>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme">light-mode</button>
    </div>

    <!-- Terminal Body -->
    <div class="terminal-body">

      <!-- Navigation -->
      <nav class="nav" aria-label="Primary">
        <div class="nav__prompt">
          <div class="powerline">
            <span class="powerline__seg powerline__seg--user">osim@dev</span>
            <span class="powerline__seg powerline__seg--path">~</span>
            <span class="powerline__seg powerline__seg--cmd">ls ./</span>
          </div>
        </div>
        <ul class="nav__links">
          <li class="nav__link"><a href="/">home</a></li>
          <li class="nav__link"><a href="/#about">about</a></li>
          <li class="nav__link"><a href="/#experience">experience</a></li>
          <li class="nav__link"><a href="/#tech">tech</a></li>
          <li class="nav__link nav__link--active"><a href="/blog">blog</a></li>
          <li class="nav__link"><a href="/#contact">contact</a></li>
          <li class="nav__link nav__link--resume"><a href="/resume.pdf" download>resume.pdf</a></li>
        </ul>
      </nav>

      <!-- Blog Header -->
      <section class="hero">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~/blog</span>
          <span class="powerline__seg powerline__seg--cmd">ls -lt ./posts/</span>
          <span class="cursor" aria-hidden="true"></span>
        </div>
      </section>

      <hr class="divider" />

      <!-- Blog Posts -->
      <section class="section">
        <div class="section__output">
          {posts.map((post) => (
            <div class="blog-entry">
              <a href={`/blog/${post.id}`} class="blog-entry__title">{post.data.title}</a>
              <span class="blog-entry__date">{post.data.date.toISOString().split('T')[0]}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Footer -->
      <footer class="footer">
        <div class="footer__prompt">
          <div class="powerline">
            <span class="powerline__seg powerline__seg--user">osim@dev</span>
            <span class="powerline__seg powerline__seg--path">~/blog</span>
            <span class="powerline__seg powerline__seg--cmd">cd ~</span>
          </div>
        </div>
        <p>&copy; 2026 osim.dev</p>
      </footer>

    </div>
  </div>
</Layout>
