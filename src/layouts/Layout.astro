---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'osim.dev — System Development Engineer',
  description = 'Portfolio of a System Development Engineer and Platform Engineer. Building platforms, enabling teams, shipping infrastructure.',
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <!-- TODO: Add og:image once we create a 1200x630 preview card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>></text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <style>
      body {
        font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', 'Monaco', monospace;
      }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      // Theme persistence
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored) {
          document.documentElement.setAttribute('data-theme', stored);
        } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();

      // Theme toggle
      document.addEventListener('DOMContentLoaded', function() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;

        function updateLabel() {
          const current = document.documentElement.getAttribute('data-theme') || 'dark';
          btn.textContent = current === 'dark' ? 'light-mode' : 'dark-mode';
          btn.setAttribute('aria-label', 'Switch to ' + (current === 'dark' ? 'light' : 'dark') + ' theme');
        }

        updateLabel();

        btn.addEventListener('click', function() {
          const current = document.documentElement.getAttribute('data-theme') || 'dark';
          const next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          updateLabel();
        });
      });

      // Experience "more" toggle
      document.addEventListener('DOMContentLoaded', function() {
        var toggle = document.getElementById('experience-toggle');
        var more = document.getElementById('experience-more');
        if (!toggle || !more) return;

        toggle.addEventListener('click', function(e) {
          e.preventDefault();
          var expanded = toggle.getAttribute('aria-expanded') === 'true';
          if (expanded) {
            more.hidden = true;
            toggle.setAttribute('aria-expanded', 'false');
            toggle.querySelector('.experience-toggle__text').textContent = '-- MORE --';
          } else {
            more.hidden = false;
            toggle.setAttribute('aria-expanded', 'true');
            toggle.querySelector('.experience-toggle__text').textContent = '-- END --';
          }
        });
      });

      // Assemble email (anti-scraper: base64 encoded)
      (function() {
        var el = document.getElementById('contact-email');
        if (!el) return;
        el.textContent = atob('Z29yYW4ub3NpbUBnbWFpbC5jb20=');
      })();

      // Spinner animation
      (function() {
        var frames = ['|', '/', '-', '\\'];
        var i = 0;
        var el = document.querySelector('.spinner');
        if (!el) return;
        setInterval(function() {
          i = (i + 1) % frames.length;
          el.textContent = frames[i];
        }, 350);
      })();

      // Job status: RUNNING (5s) → fade through compile lines → RUNNING → repeat
      (function() {
        var el = document.getElementById('job-running-text');
        if (!el) return;

        var compileLines = [
          'compiling platform.rs...',
          'linking infrastructure.o',
          'building k8s-operator v3.2.1',
          'optimizing deploy pipeline',
          'resolving dependencies...',
          'packaging observability stack',
          'compiling terraform modules',
          'linking ci-cd.pipeline.o',
          'building service-mesh v2.0',
          'optimizing resource allocator'
        ];

        var lineIndex = 0;

        function showRunning() {
          el.classList.add('job__running-text--fade');
          setTimeout(function() {
            el.textContent = 'RUNNING';
            el.className = 'job__running-text job__running-text--blink';
          }, 300);
          setTimeout(showCompileLines, 5000);
        }

        function showCompileLines() {
          var count = 0;
          function nextLine() {
            el.classList.add('job__running-text--fade');
            setTimeout(function() {
              el.textContent = compileLines[lineIndex % compileLines.length];
              el.className = 'job__running-text job__running-text--compile';
              lineIndex++;
              count++;
              if (count < 4) {
                setTimeout(nextLine, 1200);
              } else {
                setTimeout(showRunning, 1200);
              }
            }, 300);
          }
          nextLine();
        }

        // Kick off
        el.className = 'job__running-text job__running-text--blink';
        setTimeout(showCompileLines, 5000);
      })();

      // Now Playing widget
      (function() {
        var widget = document.getElementById('now-playing-widget');
        var loading = document.getElementById('np-loading');
        var track = document.getElementById('np-track');
        var offline = document.getElementById('np-offline');
        var vinylWrapper = document.getElementById('np-vinyl');
        var vinylDisc = vinylWrapper ? vinylWrapper.querySelector('.vinyl') : null;
        var labelEl = document.getElementById('np-label');
        var songEl = document.getElementById('np-song');
        var artistEl = document.getElementById('np-artist');

        if (!widget) return;

        // Preview audio
        var audio = null;
        var isPreviewPlaying = false;

        function showState(state) {
          widget.setAttribute('data-state', state);
          loading.hidden = state !== 'loading';
          track.hidden = state !== 'playing' && state !== 'recent';
          offline.hidden = state !== 'offline';
        }

        function updateTrack(data) {
          var isLive = data.is_playing;
          showState(isLive ? 'playing' : 'recent');

          labelEl.textContent = isLive ? 'Now Playing' : 'Recently Played';
          labelEl.className = 'now-playing__label' + (isLive ? ' now-playing__label--live' : '');

          songEl.textContent = data.track;
          songEl.href = data.track_url || '#';

          artistEl.textContent = data.artist;
          artistEl.href = data.artist_url || '#';

          if (vinylDisc) {
            if (isLive) {
              vinylDisc.classList.remove('vinyl--paused');
            } else {
              vinylDisc.classList.add('vinyl--paused');
            }
          }

          // Store preview URL
          if (vinylWrapper) vinylWrapper.dataset.previewUrl = data.preview_url || '';
        }

        // Preview play/pause
        if (vinylWrapper) {
          vinylWrapper.addEventListener('click', function() {
            var previewUrl = vinylWrapper.dataset.previewUrl;
            if (!previewUrl) return;

            if (isPreviewPlaying) {
              audio.pause();
              audio = null;
              isPreviewPlaying = false;
              if (vinylDisc) vinylDisc.style.animationDuration = '3s';
            } else {
              audio = new Audio(previewUrl);
              audio.volume = 0.5;
              audio.play();
              isPreviewPlaying = true;
              if (vinylDisc) vinylDisc.style.animationDuration = '1.5s';

              audio.addEventListener('ended', function() {
                isPreviewPlaying = false;
                if (vinylDisc) vinylDisc.style.animationDuration = '3s';
                audio = null;
              });
            }
          });
        }

        // Fetch from Worker API
        var API_URL = 'https://osim-now-playing.goran-osim.workers.dev';

        if (API_URL) {
          fetch(API_URL)
            .then(function(res) { return res.json(); })
            .then(function(data) {
              if (data && data.track) {
                updateTrack(data);
              } else {
                showState('offline');
              }
            })
            .catch(function() {
              showState('offline');
            });
        } else {
          // No API configured — show offline state after brief loading
          setTimeout(function() {
            showState('offline');
          }, 1500);
        }
      })();
    </script>
  </body>
</html>
