---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <div class="terminal-window">
    <!-- Window Chrome -->
    <div class="window-chrome">
      <div class="window-dots">
        <span class="window-dot window-dot--close"></span>
        <span class="window-dot window-dot--minimize"></span>
        <span class="window-dot window-dot--maximize"></span>
      </div>
      <span class="window-title">osim@dev: ~/portfolio</span>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme">light-mode</button>
    </div>

    <!-- Terminal Body -->
    <div class="terminal-body">

      <!-- Navigation -->
      <nav class="nav" aria-label="Primary">
        <div class="nav__prompt">
          <span class="prompt__user">osim</span><span class="prompt__separator">@</span><span class="prompt__host">dev</span><span class="prompt__separator">:</span><span class="prompt__path">~</span><span class="prompt__symbol">$</span> ls ./
        </div>
        <ul class="nav__links">
          <li class="nav__link"><a href="#about">about</a></li>
          <li class="nav__link"><a href="#experience">experience</a></li>
          <li class="nav__link"><a href="#tech">tech</a></li>
          <li class="nav__link"><a href="/blog">blog</a></li>
          <li class="nav__link"><a href="#contact">contact</a></li>
          <li class="nav__link nav__link--resume"><a href="/resume.pdf" download>resume.pdf</a></li>
        </ul>
      </nav>

      <!-- Hero / Bio -->
      <section class="hero" id="hero">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~</span>
          <span class="powerline__seg powerline__seg--cmd">whoami</span>
          <span class="cursor" aria-hidden="true"></span>
        </div>
        <h1 class="hero__name">Goran Osim</h1>
        <pre class="hero__ascii" aria-label="Goran Osim">
  ,ad8888ba,                                                          ,ad8888ba,
 d8"'    `"8b                                                        d8"'    `"8b             <a href="/pi" class="easter-egg" title="">&middot;π&middot;</a>
d8'                                                                 d8'        `8b
88              ,adPPYba,   8b,dPPYba,  ,adPPYYba,  8b,dPPYba,      88          88  ,adPPYba,  88  88,dPYba,,adPYba,
88      88888  a8"     "8a  88P'   "Y8  ""     `Y8  88P'   `"8a     88          88  I8[    ""  88  88P'   "88"    "8a
Y8,        88  8b       d8  88          ,adPPPPP88  88       88     Y8,        ,8P   `"Y8ba,   88  88      88      88
 Y8a.    .a88  "8a,   ,a8"  88          88,    ,88  88       88      Y8a.    .a8P   aa    ]8I  88  88      88      88
  `"Y88888P"    `"YbbdP"'   88          `"8bbdP"Y8  88       88       `"Y8888Y"'    `"YbbdP"'  88  88      88      88</pre>
        <p class="hero__title">System Development Engineer</p>
        <div class="hero__bio">
          <p>I build the platforms that engineers build on.</p>
          <p>Faster shipping, wherever the work needs to happen.</p>
        </div>
        <div class="hero__resume">
          <a href="/resume.pdf" class="resume-link" download>
            <span class="resume-link__icon">&darr;</span>
            resume.pdf
          </a>
        </div>
      </section>

      <hr class="divider" />

      <!-- About -->
      <section class="section" id="about">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~/about</span>
          <span class="powerline__seg powerline__seg--cmd">cat story.txt</span>
        </div>
        <div class="section__output">
          <div class="about__label"># personal</div>
          <div class="about__content">
            <p>I build platforms that let other engineers ship faster. For the last decade, that's meant designing and running Kubernetes-based infrastructure at scale&mdash;from self-service developer portals to air-gapped software factories for the US Air Force and DoD programs.</p>
            <p>I lead teams, mentor engineers new to the cloud, and care as much about the developer experience as the infrastructure underneath it. I've built in both commercial and government environments, internet-connected and disconnected, and I'm most useful when the problem is "we need this to work reliably for hundreds of people, yesterday."</p>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- Work Experience -->
      <section class="section" id="experience">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~/experience</span>
          <span class="powerline__seg powerline__seg--cmd">cat history.json | jq '.[]'</span>
        </div>
        <div class="section__output">
          <div class="job job--current">
            <div class="job__header">
              <span class="job__company">Amazon Web Services</span>
              <span class="job__dates">11/2025 &ndash; Present <span class="spinner" aria-hidden="true"></span></span>
            </div>
            <div class="job__title">System Development Engineer III</div>
            <div class="job__running">
              <span class="job__running-text" id="job-running-text">RUNNING</span>
            </div>
          </div>

          <div class="job">
            <div class="job__header">
              <span class="job__company">Booz Allen Hamilton</span>
              <span class="job__dates">07/2021 &ndash; 10/2025</span>
            </div>
            <div class="job__title">Chief Engineer</div>
            <ul class="job__bullets">
              <li>Led a team of 7 Platform and Cloud engineers architecting and building a secure-by-default platform-as-a-service with automated resource deployment and a self-service developer portal.</li>
              <li>Designed and implemented a project onboarding pipeline for creating AWS accounts and Kubernetes clusters within 70 minutes leveraging AWS Landing Zone Accelerator, Step Functions, and Terraform.</li>
              <li>Spearheaded and mentored a team of 5 platform engineers designing and operationalizing an enterprise software platform for the F-35 Joint Program Office, automating VMware Tanzu Kubernetes Grid deployments.</li>
              <li>Built custom GitLab CI pipelines for cross-domain software artifact deployment from inter-connected USAF environments to classified environments utilizing Amazon Diode.</li>
              <li>Established GitLab CI pipelines for testing Kubernetes Platform applications and automated infrastructure deployments across Rancher RKE2, air-gapped Kubernetes, and K3D distributions.</li>
              <li>Deployed Kubernetes clusters with autoscaling capabilities that dynamically adjust pod and cluster size, implementing horizontal and vertical autoscaling strategies utilizing event-driven and resource-driven metrics.</li>
            </ul>
          </div>

          <div class="job">
            <div class="job__header">
              <span class="job__company">Booz Allen Hamilton</span>
              <span class="job__dates">03/2019 &ndash; 07/2021</span>
            </div>
            <div class="job__title">Senior Lead Technologist</div>
            <ul class="job__bullets">
              <li>Built a standardized Platform-as-a-Service / Platform-in-a-Box for the United States Air Force under the Chief Software Officer.</li>
              <li>Led a team of 4 Engineers as the Classified Operations Technical Anchor enabling low-side development and automating deployment of software to classified environments in SIPR and JWICS.</li>
              <li>Served on the Air Force Platform One program as an Advanced Kubernetes SME, developing and deploying platform capabilities utilizing open source technologies for government Mission Application Developers.</li>
              <li>Designed and deployed production grade Kubernetes platforms hosting software factories for government contract technical challenge evaluations.</li>
              <li>Selected as the lead technical presenter and SME for government proposal evaluations, conducting live demos, presenting technical orals, and developing technical volumes for competitive contract awards.</li>
            </ul>
          </div>

          <div id="experience-more" class="experience-more" hidden>
            <div class="job">
              <div class="job__header">
                <span class="job__company">BigBear Inc</span>
                <span class="job__dates">11/2017 &ndash; 03/2019</span>
              </div>
              <div class="job__title">Infrastructure Lead</div>
              <ul class="job__bullets">
                <li>Led application teams in migrating from legacy virtual machines to custom built, high-performance compute clusters.</li>
                <li>Established automated CI/CD processes and deployment pipelines to build Docker containers and deploy into Kubernetes environments running on bare metal within a datacenter.</li>
                <li>Established the company's first large-scale performant Kubernetes cluster: 32 Nodes, 4TB RAM, 1024 Cores, and 64TB SSD storage.</li>
                <li>Grew overall company data center to 3000+ cores, 7+ TB of RAM, and 300 TB of mixed SSD/HDD storage.</li>
              </ul>
            </div>

            <div class="job">
              <div class="job__header">
                <span class="job__company">BigBear Inc</span>
                <span class="job__dates">01/2017 &ndash; 11/2017</span>
              </div>
              <div class="job__title">Senior Software Engineer</div>
              <ul class="job__bullets">
                <li>Researched and implemented modernization strategies to modify the operational stack, remove brittle deployment processes, and adopt Docker and Kubernetes.</li>
                <li>Maintained a Virtual Private Cloud with over 1500 cores and 25 Servers, supporting a Cassandra cluster comprising billions of records.</li>
                <li>Provided 24/7 support and maintenance of the private cloud and associated ingest and egress data pipelines.</li>
              </ul>
            </div>

            <div class="job">
              <div class="job__header">
                <span class="job__company">BigBear Inc</span>
                <span class="job__dates">11/2015 &ndash; 01/2017</span>
              </div>
              <div class="job__title">Senior Software Engineer</div>
              <ul class="job__bullets">
                <li>Developed an information mapping, geo-capable solution using Django backed by Elasticsearch, enabling search over 30 billion documents with highly performant queries.</li>
                <li>Created Amazon CloudFormation scripts for automated deployments and scaling for both AWS and C2S.</li>
                <li>Prototyped and implemented custom solutions utilizing RDS, SQS, EC2, and S3 to provide durable services easily deployed across multiple regions.</li>
                <li>Automated frontend and backend machine configuration using Fabric Scripts and CloudFormation for fast, seamless deployment requiring no manual interaction.</li>
              </ul>
            </div>

            <div class="job">
              <div class="job__header">
                <span class="job__company">Data Meaning</span>
                <span class="job__dates">04/2014 &ndash; 11/2015</span>
              </div>
              <div class="job__title">Software Engineer</div>
              <ul class="job__bullets">
                <li>Served on the Analytics Team of a major Hotel Company, converting outdated and complex ETL processes into logical and stable data flows.</li>
                <li>Implemented automated Python scripts for data manipulation formerly done by hand, saving time on daily, weekly, and monthly tasks.</li>
                <li>Built a custom data retrieval script to automatically scrape vendor data from APIs and transform customer data, handling instability and inconsistency errors from third party vendors.</li>
                <li>Designed and tested a conversion plan to migrate existing data flows and data warehouses to newer software versions with zero downtime.</li>
              </ul>
            </div>

            <div class="job">
              <div class="job__header">
                <span class="job__company">CGI Federal</span>
                <span class="job__dates">02/2012 &ndash; 04/2014</span>
              </div>
              <div class="job__title">Consultant / Application Developer</div>
              <ul class="job__bullets">
                <li>Technical consultant on the Momentum Technical Support team, supporting issue resolution, development, and upgrade support for Java components of the Momentum suite.</li>
                <li>Supported implementation and ongoing maintenance of Momentum for multiple Federal clients in a geographically dispersed shared pool of resources.</li>
                <li>Supported on-site project teams with new system implementations and upgrades by providing application development, testing services, and issue analysis.</li>
                <li>Interviewed and mentored new Technical Consultants through the Momentum Apprenticeship Program.</li>
              </ul>
            </div>
          </div>

          <a href="#" id="experience-toggle" class="experience-toggle" aria-expanded="false">
            <span class="experience-toggle__text">-- MORE --</span>
            <span class="cursor" aria-hidden="true"></span>
          </a>
        </div>
      </section>

      <hr class="divider" />

      <!-- Tech & Tools -->
      <section class="section" id="tech">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~/tech</span>
          <span class="powerline__seg powerline__seg--cmd">htop --filter="tools,platforms,languages"</span>
        </div>
        <div class="section__output">
          <div class="htop">
            <div class="htop__header">
              <span class="htop__pid">PID</span>
              <span class="htop__tool">COMMAND</span>
              <span class="htop__cat">GROUP</span>
              <span class="htop__exp">YRS</span>
              <span class="htop__status">STATUS</span>
            </div>
            <div class="htop__row"><span class="htop__pid">1001</span><span class="htop__tool">GitHub Actions</span><span class="htop__cat">cicd</span><span class="htop__exp">5y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1002</span><span class="htop__tool">GitOps</span><span class="htop__cat">cicd</span><span class="htop__exp">3y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1003</span><span class="htop__tool">Jenkins</span><span class="htop__cat">cicd</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1004</span><span class="htop__tool">AWS</span><span class="htop__cat">cloud</span><span class="htop__exp">5y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1005</span><span class="htop__tool">GCP</span><span class="htop__cat">cloud</span><span class="htop__exp">3y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1006</span><span class="htop__tool">ArgoCD</span><span class="htop__cat">containers</span><span class="htop__exp">3y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1007</span><span class="htop__tool">Docker</span><span class="htop__cat">containers</span><span class="htop__exp">6y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1008</span><span class="htop__tool">Helm</span><span class="htop__cat">containers</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1009</span><span class="htop__tool">Kubernetes</span><span class="htop__cat">containers</span><span class="htop__exp">5y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1010</span><span class="htop__tool">Kafka</span><span class="htop__cat">data</span><span class="htop__exp">3y</span><span class="htop__status"><span class="htop__tag htop__tag--familiar">familiar</span></span></div>
            <div class="htop__row"><span class="htop__pid">1011</span><span class="htop__tool">PostgreSQL</span><span class="htop__cat">data</span><span class="htop__exp">5y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1012</span><span class="htop__tool">Redis</span><span class="htop__cat">data</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1013</span><span class="htop__tool">Ansible</span><span class="htop__cat">iac</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1014</span><span class="htop__tool">Pulumi</span><span class="htop__cat">iac</span><span class="htop__exp">2y</span><span class="htop__status"><span class="htop__tag htop__tag--familiar">familiar</span></span></div>
            <div class="htop__row"><span class="htop__pid">1015</span><span class="htop__tool">Terraform</span><span class="htop__cat">iac</span><span class="htop__exp">5y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1016</span><span class="htop__tool">Bash</span><span class="htop__cat">languages</span><span class="htop__exp">8y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1017</span><span class="htop__tool">Go</span><span class="htop__cat">languages</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1018</span><span class="htop__tool">Python</span><span class="htop__cat">languages</span><span class="htop__exp">6y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1019</span><span class="htop__tool">gRPC</span><span class="htop__cat">networking</span><span class="htop__exp">3y</span><span class="htop__status"><span class="htop__tag htop__tag--familiar">familiar</span></span></div>
            <div class="htop__row"><span class="htop__pid">1020</span><span class="htop__tool">Nginx</span><span class="htop__cat">networking</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1021</span><span class="htop__tool">REST APIs</span><span class="htop__cat">networking</span><span class="htop__exp">6y+</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1022</span><span class="htop__tool">Grafana</span><span class="htop__cat">o11y</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1023</span><span class="htop__tool">OpenTelemetry</span><span class="htop__cat">o11y</span><span class="htop__exp">2y</span><span class="htop__status"><span class="htop__tag htop__tag--familiar">familiar</span></span></div>
            <div class="htop__row"><span class="htop__pid">1024</span><span class="htop__tool">Prometheus</span><span class="htop__cat">o11y</span><span class="htop__exp">4y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
            <div class="htop__row"><span class="htop__pid">1025</span><span class="htop__tool">Linux</span><span class="htop__cat">os</span><span class="htop__exp">10y</span><span class="htop__status"><span class="htop__tag htop__tag--production">production</span></span></div>
          </div>
        </div>
      </section>

      <hr class="divider" />

      <!-- Contact / Social -->
      <section class="section" id="contact">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~/contact</span>
          <span class="powerline__seg powerline__seg--cmd">cat links.yml</span>
        </div>
        <div class="section__output">
          <pre class="contact-yaml"><span class="yaml__key">github:</span>   <a href="https://github.com/salt-mountain" target="_blank" rel="noopener noreferrer">github.com/salt-mountain</a>
<span class="yaml__key">linkedin:</span> <a href="https://www.linkedin.com/in/goranosim/" target="_blank" rel="noopener noreferrer">linkedin.com/in/goranosim</a>
<span class="yaml__key">email:</span>    goran.osim [at] gmail.com</pre>
        </div>
      </section>

      <hr class="divider" />

      <!-- Now Playing Widget -->
      <section class="section" id="now-playing">
        <div class="powerline">
          <span class="powerline__seg powerline__seg--user">osim@dev</span>
          <span class="powerline__seg powerline__seg--path">~</span>
          <span class="powerline__seg powerline__seg--cmd">now-playing --status</span>
        </div>
        <div class="section__output">
          <div class="now-playing">
            <div class="vinyl" aria-hidden="true"></div>
            <div class="now-playing__info">
              <span class="now-playing__label">Now Playing</span>
              <span class="now-playing__song">Midnight City</span>
              <span class="now-playing__artist">M83</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="footer">
        <div class="footer__prompt">
          <span class="prompt__user">osim</span><span class="prompt__separator">@</span><span class="prompt__host">dev</span><span class="prompt__separator">:</span><span class="prompt__path">~</span><span class="prompt__symbol">$</span> exit
        </div>
        <p>&copy; 2026 osim.dev &middot; Built with Astro &middot; Served statically</p>
      </footer>

    </div>
  </div>
</Layout>
