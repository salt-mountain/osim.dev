          <span class="prompt__user">osim</span><span class="prompt__separator">@</span><span class="prompt__host">dev</span><span class="prompt__separator">:</span><span class="prompt__path">~</span><span class="prompt__symbol">$</span> ls ./
        </div>
        <ul class="nav__links">
          <li class="nav__link"><a href="/">home</a></li>
          <li class="nav__link"><a href="/#about">about</a></li>
          <li class="nav__link"><a href="/#experience">experience</a></li>
